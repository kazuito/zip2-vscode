{
  "name": "zip2",
  "displayName": "Zip2",
  "description": "Quick search for workspace functions and React-style components.",
  "version": "0.0.1",
  "publisher": "kazuito",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/kazuito/zip2-vscode.git"
  },
  "homepage": "https://github.com/kazuito/zip2-vscode#readme",
  "bugs": {
    "url": "https://github.com/kazuito/zip2-vscode/issues"
  },
  "keywords": [
    "search",
    "symbols",
    "functions",
    "components",
    "hooks",
    "react",
    "navigation",
    "typescript",
    "javascript"
  ],
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "pnpm bundle",
    "bundle": "rolldown --config rolldown.config.ts",
    "watch": "rolldown --config rolldown.config.ts --watch",
    "compile-tests": "node ./scripts/compile-tests.mjs",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "pnpm biome check --write --unsafe && pnpm typecheck",
    "pretest": "pnpm bundle && pnpm compile-tests",
    "test": "vscode-test",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "contributes": {
    "configuration": {
      "title": "Zip2",
      "properties": {
        "zip2.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional glob patterns to exclude from indexing (e.g. [\"**/generated/**\", \"**/.turbo/**\"])."
        },
        "zip2.respectGitignore": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, files and folders matched by any .gitignore file in the workspace are excluded from indexing. Takes effect on the next reload."
        },
        "zip2.functionLabelFormat": {
          "type": "string",
          "default": "${name}()",
          "description": "Label format for functions. Use ${name} as a placeholder for the symbol name."
        },
        "zip2.componentLabelFormat": {
          "type": "string",
          "default": "<${name} />",
          "description": "Label format for components. Use ${name} as a placeholder for the symbol name."
        },
        "zip2.hookLabelFormat": {
          "type": "string",
          "default": "${name}()",
          "description": "Label format for hooks. Use ${name} as a placeholder for the symbol name."
        }
      }
    },
    "commands": [
      {
        "command": "zip2.searchSymbols",
        "title": "Search Symbols",
        "category": "Zip2"
      },
      {
        "command": "zip2.searchComponents",
        "title": "Search Components",
        "category": "Zip2"
      },
      {
        "command": "zip2.searchFunctions",
        "title": "Search Functions",
        "category": "Zip2"
      },
      {
        "command": "zip2.searchHooks",
        "title": "Search Hooks",
        "category": "Zip2"
      }
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "husky": "^9.1.7",
    "rolldown": "1.0.0-rc.12",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "ignore": "^7.0.5"
  }
}
