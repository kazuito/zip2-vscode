{
  "name": "zip2",
  "displayName": "Zip2",
  "description": "Quick search for workspace functions and React-style components.",
  "version": "0.0.1",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Zip2",
      "properties": {
        "zip2.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional glob patterns to exclude from indexing (e.g. [\"**/generated/**\", \"**/.turbo/**\"])."
        }
      }
    },
    "commands": [
      {
        "command": "zip2.searchSymbols",
        "title": "Search Components and Functions",
        "category": "Zip2"
      },
      {
        "command": "zip2.searchComponents",
        "title": "Search Components",
        "category": "Zip2"
      },
      {
        "command": "zip2.searchFunctions",
        "title": "Search Functions",
        "category": "Zip2"
      },
      {
        "command": "zip2.searchHooks",
        "title": "Search Hooks",
        "category": "Zip2"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm bundle",
    "bundle": "rolldown --config rolldown.config.ts",
    "watch": "rolldown --config rolldown.config.ts --watch",
    "compile-tests": "node ./scripts/compile-tests.mjs",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "pnpm biome check --write --unsafe && pnpm typecheck",
    "pretest": "pnpm bundle && pnpm compile-tests",
    "test": "vscode-test",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "husky": "^9.1.7",
    "npm-run-all": "^4.1.5",
    "rolldown": "1.0.0-rc.12",
    "typescript": "^5.9.3"
  }
}
