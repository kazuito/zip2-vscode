{
  "name": "zip2",
  "displayName": "Zip2",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "zip2.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm bundle",
    "bundle": "rolldown --config rolldown.config.ts",
    "watch": "rolldown --config rolldown.config.ts --watch",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "pnpm biome check --write --unsafe && pnpm typecheck",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "husky": "^9.1.7",
    "npm-run-all": "^4.1.5",
    "rolldown": "1.0.0-rc.12",
    "typescript": "^5.9.3"
  }
}
